# Backend runtime
PORT=3000
NODE_ENV=production

# Redis
REDIS_URL=redis://127.0.0.1:6379
# If running in docker-compose network, use:
# REDIS_URL=redis://redis:6379
# If Redis requires auth, use:
# REDIS_URL=redis://:your_password@127.0.0.1:6379/0

# Storage paths
STORAGE_DIR=storage
UPLOAD_DIR=storage/uploads
OUTPUT_DIR=storage/outputs

# Limits / worker behavior
MAX_UPLOAD_SIZE_BYTES=2147483648
WORKER_CONCURRENCY=3
FILE_TTL_HOURS=24

# OCR (hard subtitles)
OCR_LANG=chi_sim
OCR_INTERVAL_SEC=0.5
OCR_MIN_CONFIDENCE=60
OCR_PSM=6
OCR_CROP_BOTTOM_RATIO=0.22
OCR_MIN_STABLE_FRAMES=2
OCR_MAX_GAP_FRAMES=1
OCR_ENGINE=tesseract
# For cloud OCR provider mode set OCR_ENGINE=http and provide endpoint
OCR_HTTP_URL=
OCR_HTTP_TIMEOUT_MS=15000
OCR_HTTP_BATCH_SIZE=8
